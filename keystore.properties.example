# Copy to keystore.properties (not committed) and set paths/passwords.
# Create a keystore once, e.g.:
#   keytool -genkey -v -keystore upload-keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# In Play Console: use the same certificate as "Upload key" (first upload registers it).

storeFile=upload-keystore.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
